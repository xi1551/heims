<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.mapper.DepartmentMapper">

    <select id="findAll" resultType="Department">
        SELECT id, name, phone, location
        FROM department
    </select>

    <select id="findById" parameterType="Long" resultType="Department">
        SELECT id, name, phone, location
        FROM department
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="Department" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO department (name, phone, location)
        VALUES (#{name}, #{phone}, #{location})
    </insert>

    <update id="update" parameterType="Department">
        UPDATE department
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="location != null">location = #{location},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        DELETE FROM department WHERE id = #{id}
    </delete>

</mapper>
